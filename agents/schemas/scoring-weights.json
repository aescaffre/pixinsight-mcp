{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scoring Weights",
  "description": "Target-specific weighting profiles for the scoring model",
  "type": "object",
  "properties": {
    "galaxy_spiral": {
      "type": "object",
      "properties": {
        "detail_credibility": { "type": "number", "default": 1.0 },
        "background_quality": { "type": "number", "default": 0.75 },
        "color_naturalness": { "type": "number", "default": 0.60 },
        "star_integrity": { "type": "number", "default": 0.50 },
        "tonal_balance": { "type": "number", "default": 0.85 },
        "subject_separation": { "type": "number", "default": 0.70 },
        "artifact_penalty": { "type": "number", "default": 0.20 },
        "aesthetic_coherence": { "type": "number", "default": 0.70 }
      }
    },
    "emission_nebula": {
      "type": "object",
      "properties": {
        "detail_credibility": { "type": "number", "default": 0.75 },
        "background_quality": { "type": "number", "default": 0.65 },
        "color_naturalness": { "type": "number", "default": 1.0 },
        "star_integrity": { "type": "number", "default": 0.55 },
        "tonal_balance": { "type": "number", "default": 0.70 },
        "subject_separation": { "type": "number", "default": 0.95 },
        "artifact_penalty": { "type": "number", "default": 0.20 },
        "aesthetic_coherence": { "type": "number", "default": 0.85 }
      }
    }
  }
}
