{
  "planetary_nebula": {
    "description": "Small, round, faint shells. M97 (Owl), M27 (Dumbbell), M57 (Ring), NGC 7293 (Helix)",
    "characteristics": {
      "typical_size": "small",
      "dynamic_range": "low",
      "has_bright_core": false,
      "color_signature": "emission",
      "star_density": "moderate"
    },
    "stretch": {
      "target_median": 0.18,
      "headroom": 0.05
    },
    "tools": {
      "GC": { "use": true },
      "ABE": { "use": "try", "reason": "Compare with GC if gradients persist" },
      "BXT": { "use": true, "correct_only": true },
      "SPCC": { "use": true },
      "SCNR": { "use": "try", "reason": "Only if SPCC fails" },
      "NXT": { "use": true, "denoise_linear": 0.20, "denoise_post_stretch": 0.25 },
      "SXT": { "use": true, "safe": true },
      "LHE": { "use": true, "start_amount": 0.25, "start_radius": 64, "mask_blur": 8, "mask_clipLow": 0.06 },
      "HDRMT": { "use": false, "reason": "No bright core to compress. Faint structure only — LHE is sufficient." },
      "LRGB": { "use": true, "lightness": 0.50, "saturation": 0.80 },
      "Ha_injection": { "use": "try", "reason": "Can enhance shell structure if Ha data available" }
    },
    "saturation": {
      "rgb_initial": 0.63,
      "composition_target": 0.70,
      "hue_selective": false
    },
    "stars": {
      "screen_blend_strength": 1.00,
      "prominence": "balanced"
    },
    "notes": "Focus on revealing internal structure (eyes, shells). Color is teal/green for OIII-dominant. Background should be darker than nebula body but not crushed.",
    "learned_overrides": {}
  },

  "galaxy_spiral": {
    "description": "Face-on spiral. M81, M51, M33, M101, M106",
    "characteristics": {
      "typical_size": "large",
      "dynamic_range": "high",
      "has_bright_core": true,
      "color_signature": "broadband",
      "star_density": "moderate"
