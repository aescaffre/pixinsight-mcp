    "tools": {
      "GC": { "use": true },
      "ABE": { "use": "try", "reason": "Compare with GC — ABE deg2 often gentler for galaxies" },
      "BXT": { "use": true, "correct_only": true },
      "SPCC": { "use": true },
      "SCNR": { "use": "try", "reason": "Only if SPCC fails, amount 0.30-0.35" },
      "NXT": { "use": true, "denoise_linear": 0.18, "denoise_post_stretch": 0.25 },
      "SXT": { "use": true, "safe": false, "caution": "Leaves residuals on HII regions and spiral knots" },
      "LHE": { "use": true, "start_amount": 0.20, "start_radius": 128, "mask_blur": 6, "mask_clipLow": 0.10, "mask_gamma": 2.0 },
      "HDRMT": { "use": true, "inverted": true, "layers": 6, "iterations": 1, "mask_clipLow": 0.30, "reason": "Essential for core and arm detail" },
      "LRGB": { "use": true, "lightness": 0.55, "saturation": 0.80 },
      "Ha_injection": { "use": "try", "reason": "Useful for HII regions if Ha data available", "strength": 0.25 }
    },
    "saturation": {
      "rgb_initial": 0.63,
      "composition_target": 0.65,
      "hue_selective": true,
      "blue_boost": 1.30,
      "pink_boost": 1.25
    },
    "stars": {
      "screen_blend_strength": 1.00,
      "prominence": "subdued"
    },
    "notes": "Dark background (0.10-0.12). IFN may be present — preserve with gentle shadow handling. Dust lanes and spiral arms are primary detail targets. Core easily clips — use headroom.",
    "learned_overrides": {}
  },

